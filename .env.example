# Copy this file to .env and fill in real values before running locally.
# Never commit .env to version control — it is listed in .gitignore.

# Secret key used to sign and verify JWT tokens.
# Must be a cryptographically random string of at least 32 characters.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me

# HTTP port the server listens on (optional, defaults to 3001).
PORT=3001

# Optional: encrypt idempotency payloads stored in Redis with AES-256-GCM.
# Leave disabled unless you have generated and securely provisioned 32-byte base64 keys.
IDEMPOTENCY_REDIS_ENCRYPTION_ENABLED=false
IDEMPOTENCY_REDIS_ENCRYPTION_ACTIVE_KEY_ID=
IDEMPOTENCY_REDIS_ENCRYPTION_ACTIVE_KEY=
# Comma-separated key-id:base64-key entries kept temporarily for decryption during rotation.
IDEMPOTENCY_REDIS_ENCRYPTION_PREVIOUS_KEYS=
