{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/buyer-profile",
    "src/cache",
    "src/clients",
    "src/db",
    "src/metrics.ts",
    "src/middleware/auth.middleware.ts",
    "src/middleware/featureFlags.ts",
    "src/middleware/idempotency.ts",
    "src/middleware/rateLimiter.ts",
    "src/routes/checkout.ts",
    "src/routes/slots.ts",
    "src/scripts",
    "src/tracing",
    "src/utils/redis.ts"
  ]
}
